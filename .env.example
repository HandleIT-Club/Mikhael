# API keys (al menos una recomendada — Groq tiene tier gratuito generoso)
GROQ_API_KEY=tu_api_key_de_groq
CEREBRAS_API_KEY=tu_api_key_de_cerebras
SAMBANOVA_API_KEY=tu_api_key_de_sambanova

# Ollama local (opcional)
OLLAMA_URL=http://localhost:11434/v1/

# URL del servidor Mikhael (la usa el CLI y los dispositivos).
# Con docker compose el puerto expuesto es 7777. Si correrás Mikhael
# directo con bin/dev (sin Docker), cambiá a http://localhost:3000.
MIKHAEL_URL=http://localhost:7777

# Auth: Mikhael ahora usa multi-user (email + password). Las cuentas se crean
# vía consola, no hay signup público:
#   bin/rails users:create EMAIL=tu@email.com PASSWORD=algo_de_12_chars_min
# El comando imprime el api_token del user. Pegalo acá para que el CLI
# (bin/mikhael) pueda autenticar contra /api/v1/*:
MIKHAEL_API_TOKEN=

# Brute-force protection del login (intentos por minuto por IP). Default: 5.
# RATE_LIMIT_LOGIN_PER_MIN=5

# Zona horaria. Fallback si no abrís la web (donde se autodetecta del browser)
# y si no configuraste con /zona en Telegram. La usa el AI para interpretar
# "mañana a las 8" en hora local, y aplica a la confirmación de recordatorios.
# Default: UTC. Ejemplos: "Buenos Aires", "Madrid", "Mexico City", "America/New_York".
# MIKHAEL_TZ=Buenos Aires

# Hosts aceptados en producción (Rails 8 DNS rebinding protection). Lista
# comma-separated. SIN ESTO, producción rechaza todos los requests — es
# obligatorio antes del primer deploy real.
# MIKHAEL_HOSTS=mikhael.mi-dominio.com,www.mikhael.mi-dominio.com

# Telegram bot (opcional). Si está seteado y hay users con telegram_chat_id
# vinculado, "bin/dev" arranca el polling automáticamente. Cada user
# vincula su chat_id desde /settings (admin) o vía el campo del CRUD.
# Para obtener un token: hablale a @BotFather en Telegram.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# MQTT push para devices (opcional). Si está seteado, las acciones
# decididas por DispatchAction se publican a mikhael/devices/<id>/command
# para que el ESP32 las consuma.
# MQTT_URL=mqtt://user:pass@localhost:1883

# ─── Docker (uso doméstico) ─────────────────────────────────────
# Camino más fácil: copiá este archivo a .env, poné tu GROQ_API_KEY
# arriba, y corré:
#   docker compose up -d
# Mikhael queda en http://localhost:7777 (puerto = 7×4, perfección
# divina al cuadruple). La primera visita te lleva al wizard /setup
# para crear el primer admin.
