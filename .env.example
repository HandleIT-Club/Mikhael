# API keys (al menos una recomendada — Groq tiene tier gratuito generoso)
GROQ_API_KEY=tu_api_key_de_groq
CEREBRAS_API_KEY=tu_api_key_de_cerebras
SAMBANOVA_API_KEY=tu_api_key_de_sambanova

# Ollama local (opcional)
OLLAMA_URL=http://localhost:11434/v1/

# URL del servidor Mikhael (la usa el CLI y los dispositivos)
MIKHAEL_URL=http://localhost:3000

# Si seteás MIKHAEL_PASSWORD, todas las rutas web y de gestión van detrás de
# HTTP Basic Auth. El endpoint /api/v1/action queda solo con auth por token.
# Recomendado si exponés Mikhael fuera de localhost o LAN de confianza.
# MIKHAEL_PASSWORD=elegí_una_buena

# Zona horaria. Fallback si no abrís la web (donde se autodetecta del browser)
# y si no configuraste con /zona en Telegram. La usa el AI para interpretar
# "mañana a las 8" en hora local, y aplica a la confirmación de recordatorios.
# Default: UTC. Ejemplos: "Buenos Aires", "Madrid", "Mexico City", "America/New_York".
# MIKHAEL_TZ=Buenos Aires
