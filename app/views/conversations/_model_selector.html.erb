<%= form_with url: conversation_path(conversation), method: :patch, class: "inline" do |f| %>
  <%= f.select :model_id,
        grouped_options_for_select(conversation_model_options, conversation.model_id),
        {},
        class: "bg-transparent text-xs text-zinc-500 border-0 focus:outline-none cursor-pointer hover:text-zinc-400 transition-colors -ml-1 pr-1",
        onchange: "this.form.requestSubmit()",
        title: "Cambiar modelo" %>
<% end %>
