<div class="group flex items-center gap-2 rounded-lg px-3 py-2 hover:bg-zinc-800 transition-colors">
  <%= link_to conversation_path(conversation),
        class: "flex-1 min-w-0" do %>
    <p class="text-sm text-zinc-300 truncate"><%= conversation.title %></p>
    <p class="text-xs text-zinc-600 mt-0.5">
      <%= conversation.provider == "groq" ? "Groq" : "Ollama" %> · <%= conversation.model_id %>
    </p>
  <% end %>

  <%= button_to conversation_path(conversation), method: :delete,
        class: "opacity-0 group-hover:opacity-100 p-1 rounded text-zinc-600 hover:text-red-400 transition-all",
        data: { turbo_confirm: "¿Eliminar esta conversación?" } do %>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  <% end %>
</div>
