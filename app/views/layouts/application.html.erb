<!DOCTYPE html>
<html lang="es" class="h-full">
  <head>
    <title><%= content_for(:title) || "Mikhael" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-zinc-950 text-zinc-100 antialiased" data-controller="timezone">
    <% if user_signed_in? %>
      <div class="fixed top-3 right-3 z-50 flex items-center gap-2 bg-zinc-900/90 backdrop-blur border border-zinc-800 rounded-lg px-3 py-1.5 text-xs text-zinc-400 shadow-lg">
        <span class="truncate max-w-[160px]"><%= current_user.email %></span>
        <%= button_to "Salir", session_path, method: :delete,
              class: "text-zinc-400 hover:text-amber-400 cursor-pointer",
              form: { class: "inline" } %>
      </div>
    <% end %>

    <div id="flash" class="fixed top-16 right-4 z-50 space-y-2 max-w-sm">
      <% if notice %>
        <%= render "shared/flash", type: :notice, message: notice %>
      <% end %>
      <% if alert %>
        <%= render "shared/flash", type: :alert, message: alert %>
      <% end %>
    </div>

    <%# Banner one-shot del API token recién creado (setup wizard, o regenerate
        en /settings). Lo mostramos prominente porque es la ÚNICA vez. %>
    <% if flash[:reveal_token] %>
      <div class="fixed bottom-4 left-4 right-4 md:left-auto md:right-4 md:max-w-md z-50 bg-amber-500/10 border border-amber-500/40 rounded-xl p-4 shadow-2xl">
        <p class="text-xs text-amber-400 font-medium mb-2">⚠ Tu API token (solo se muestra ahora — guardalo):</p>
        <code class="block text-xs text-amber-300 font-mono break-all bg-zinc-950 px-3 py-2 rounded select-all"><%= flash[:reveal_token] %></code>
        <p class="text-xs text-zinc-500 mt-2">Pegalo en tu <code class="text-amber-400">.env</code> como <code class="text-amber-400">MIKHAEL_API_TOKEN=...</code> para el CLI.</p>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
