<% content_for :title, "Configuración" %>

<div class="flex h-screen w-full">
  <%# Sidebar %>
  <aside class="w-72 flex-shrink-0 border-r border-zinc-800 flex flex-col">
    <div class="p-5 border-b border-zinc-800">
      <%= link_to conversations_path, class: "text-amber-400 font-bold tracking-widest text-sm uppercase hover:text-amber-300 transition-colors" do %>
        M I K H A E L
      <% end %>
    </div>

    <div class="p-4 space-y-2">
      <%= link_to "← Volver al chat", conversations_path,
            class: "block w-full py-2 px-4 rounded-lg bg-zinc-800 hover:bg-zinc-700 text-zinc-300 text-sm transition-colors text-center" %>
    </div>

    <div class="p-4 border-t border-zinc-800">
      <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium">Contextos</p>
      <p class="text-xs text-zinc-600 mt-2 leading-relaxed">
        Configurá el system prompt de cada modelo. Se aplica a todas las conversaciones nuevas y existentes.
      </p>
    </div>
  </aside>

  <%# Main %>
  <main class="flex-1 overflow-y-auto">
    <div class="max-w-4xl mx-auto px-8 py-6">
      <h1 class="text-2xl font-thin text-amber-400 tracking-wide mb-2">Configuración</h1>
      <p class="text-zinc-500 text-sm mb-6">
        Estado de integraciones y system prompts por modelo.
      </p>

      <%= render "shared/integrations_status" %>

      <h2 class="text-amber-400 text-sm font-medium uppercase tracking-widest mb-3 mt-8">Contextos de los modelos</h2>
      <p class="text-zinc-500 text-xs mb-4">
        Cada modelo tiene su propio system prompt. Se aplica a todas las conversaciones nuevas y existentes.
      </p>

      <div class="space-y-6">
        <% @configs.each do |config| %>
          <% badge = provider_badge(Conversation.all_models[config.model_id]) %>
          <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
            <div class="flex items-baseline justify-between mb-3">
              <h2 class="text-zinc-100 font-medium font-mono text-sm"><%= config.model_id %></h2>
              <span class="text-xs px-2 py-0.5 rounded <%= badge[:css] %>">
                <%= badge[:label] %>
              </span>
            </div>

            <%= form_with model: config, local: true, class: "space-y-3" do |f| %>
              <%= f.text_area :system_prompt, rows: 6,
                    class: "w-full bg-zinc-950 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 placeholder-zinc-600 focus:outline-none focus:border-amber-500 resize-none font-mono leading-relaxed" %>
              <div class="flex justify-end">
                <%= f.submit "Guardar",
                      class: "px-4 py-2 bg-amber-500 hover:bg-amber-400 text-zinc-950 font-semibold rounded-lg text-sm transition-colors cursor-pointer" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </main>
</div>
