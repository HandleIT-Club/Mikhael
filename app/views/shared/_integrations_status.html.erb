<%
  providers = [
    { name: "Groq",      env: "GROQ_API_KEY",      free_tier_url: "https://console.groq.com" },
    { name: "Cerebras",  env: "CEREBRAS_API_KEY",  free_tier_url: "https://cloud.cerebras.ai" },
    { name: "SambaNova", env: "SAMBANOVA_API_KEY", free_tier_url: "https://cloud.sambanova.ai" }
  ]
  ollama_count       = OllamaModels.installed.size
  mqtt_url           = ENV["MQTT_URL"].to_s.strip
  telegram_token     = ENV["TELEGRAM_BOT_TOKEN"].to_s.strip
  # Multi-user: el chat_id ya no vive en ENV. Telegram está activo si el
  # bot token está + hay al menos un User con telegram_chat_id vinculado.
  telegram_users     = telegram_token.present? ? User.where.not(telegram_chat_id: nil).count : 0
  telegram_active    = telegram_token.present? && telegram_users.positive?
  configured         = providers.count { |p| ENV[p[:env]].to_s.strip.present? }
%>

<div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 mb-6">
  <h2 class="text-amber-400 text-sm font-medium uppercase tracking-widest mb-3">Estado de integraciones</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
    <%# Providers de IA %>
    <div>
      <p class="text-zinc-400 text-xs uppercase tracking-wider mb-2">Providers de IA cloud</p>
      <ul class="space-y-1">
        <% providers.each do |p| %>
          <% present = ENV[p[:env]].to_s.strip.present? %>
          <li class="flex items-center justify-between gap-2">
            <span class="<%= present ? 'text-zinc-200' : 'text-zinc-500' %>">
              <%= present ? "✓" : "✗" %> <%= p[:name] %>
            </span>
            <% unless present %>
              <%= link_to "obtener key →", p[:free_tier_url], target: "_blank",
                    class: "text-xs text-amber-500 hover:text-amber-400" %>
            <% end %>
          </li>
        <% end %>
        <li class="flex items-center justify-between gap-2 pt-1 border-t border-zinc-800 mt-1">
          <span class="<%= ollama_count > 0 ? 'text-zinc-200' : 'text-zinc-500' %>">
            <%= ollama_count > 0 ? "✓" : "✗" %> Ollama (local)
          </span>
          <span class="text-xs text-zinc-600">
            <%= ollama_count > 0 ? "#{ollama_count} modelo#{'s' if ollama_count != 1}" : "no instalado" %>
          </span>
        </li>
      </ul>
      <% if configured.zero? && ollama_count.zero? %>
        <p class="text-xs text-red-400 mt-2">⚠ No hay ningún provider configurado — Mikhael no puede responder.</p>
      <% elsif configured == 1 %>
        <p class="text-xs text-zinc-500 mt-2">💡 Solo tenés 1 provider cloud. Si te quedás sin rate limit, no hay fallback.</p>
      <% end %>
    </div>

    <%# Integraciones %>
    <div>
      <p class="text-zinc-400 text-xs uppercase tracking-wider mb-2">Otras integraciones</p>
      <ul class="space-y-1">
        <li class="<%= mqtt_url.empty? ? 'text-zinc-500' : 'text-zinc-200' %>">
          <%= mqtt_url.empty? ? "✗" : "✓" %> MQTT push
          <% unless mqtt_url.empty? %>
            <span class="text-xs text-zinc-600 ml-1"><%= mqtt_url %></span>
          <% end %>
        </li>
        <li class="<%= telegram_active ? 'text-zinc-200' : 'text-zinc-500' %>">
          <%= telegram_active ? "✓" : "✗" %> Telegram bot
          <% if telegram_active %>
            <span class="text-xs text-zinc-600 ml-1"><%= telegram_users %> user<%= "s" if telegram_users != 1 %> vinculado<%= "s" if telegram_users != 1 %></span>
          <% elsif telegram_token.present? %>
            <span class="text-xs text-zinc-600 ml-1">(sin users vinculados — vinculá un chat_id en Configuración)</span>
          <% end %>
        </li>
      </ul>
      <p class="text-xs text-zinc-600 mt-2">
        ENV (token, MQTT) en <code class="text-amber-500">.env</code>. Vinculación Telegram por user en Configuración.
      </p>
    </div>
  </div>
</div>
