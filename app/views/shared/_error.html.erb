<div data-controller="flash"
     class="flex items-start gap-3 px-4 py-3 rounded-lg text-sm font-medium shadow-lg bg-zinc-800 border border-red-500/30 text-red-400">
  <span class="flex-1"><%= t("errors.ai.#{error}", default: t("errors.ai.default")) %></span>
  <button data-action="click->flash#dismiss" class="shrink-0 opacity-60 hover:opacity-100 transition-opacity leading-none">✕</button>
</div>
