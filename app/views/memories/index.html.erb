<% content_for :title, "Memorias" %>

<div class="flex h-screen w-full">
  <%# Sidebar %>
  <aside class="w-72 flex-shrink-0 border-r border-zinc-800 flex flex-col">
    <div class="p-5 border-b border-zinc-800">
      <%= link_to conversations_path, class: "text-amber-400 font-bold tracking-widest text-sm uppercase hover:text-amber-300 transition-colors" do %>
        M I K H A E L
      <% end %>
    </div>

    <div class="p-4 space-y-2">
      <%= link_to "← Volver al chat", conversations_path,
            class: "block w-full py-2 px-4 rounded-lg bg-zinc-800 hover:bg-zinc-700 text-zinc-300 text-sm transition-colors text-center" %>
    </div>

    <div class="p-4 border-t border-zinc-800 mt-auto">
      <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium">Memorias</p>
      <p class="text-xs text-zinc-600 mt-2 leading-relaxed">
        Resúmenes de conversaciones pasadas. Mikhael los usa para mantener contexto entre sesiones.
      </p>
    </div>
  </aside>

  <%# Main %>
  <main class="flex-1 overflow-y-auto">
    <div class="max-w-3xl mx-auto px-8 py-6">
      <div class="flex items-baseline justify-between mb-6">
        <h1 class="text-2xl font-thin text-amber-400 tracking-wide">Memorias</h1>
        <span class="text-zinc-600 text-sm"><%= @memories.total_count rescue @memories.count %> guardadas</span>
      </div>

      <%# Búsqueda %>
      <%= form_with url: memories_path, method: :get, local: true, class: "mb-6" do |f| %>
        <div class="flex gap-2">
          <%= f.text_field :q, value: @query,
                placeholder: "buscar por keyword...",
                class: "flex-1 bg-zinc-900 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-500" %>
          <%= f.submit "Buscar",
                class: "px-4 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 rounded-lg text-sm transition-colors cursor-pointer" %>
          <% if @query.present? %>
            <%= link_to "✕", memories_path,
                  class: "px-3 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-400 rounded-lg text-sm transition-colors" %>
          <% end %>
        </div>
      <% end %>

      <%# Lista %>
      <div class="space-y-3">
        <% @memories.each do |memory| %>
          <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-4">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <p class="text-zinc-200 text-sm leading-relaxed"><%= memory.summary %></p>
                <div class="flex items-center gap-3 mt-2">
                  <span class="text-xs text-zinc-600"><%= memory.created_at.strftime("%-d %b %Y, %H:%M") %></span>
                  <span class="text-xs text-zinc-700">·</span>
                  <div class="flex flex-wrap gap-1">
                    <% memory.keywords.split(",").each do |kw| %>
                      <span class="text-xs px-1.5 py-0.5 bg-zinc-800 text-zinc-500 rounded font-mono"><%= kw.strip %></span>
                    <% end %>
                  </div>
                </div>
              </div>

              <%= button_to memory_path(memory), method: :delete,
                    class: "flex-shrink-0 text-xs px-2.5 py-1.5 rounded-lg border border-zinc-700 text-zinc-500 hover:border-red-500/40 hover:text-red-400 transition-colors cursor-pointer",
                    data: { turbo_confirm: "¿Eliminar esta memoria?" } do %>
                ✕
              <% end %>
            </div>
          </div>
        <% end %>

        <% if @memories.empty? %>
          <div class="text-center py-16">
            <p class="text-zinc-600 text-sm">
              <% if @query.present? %>
                No hay memorias que contengan "<%= @query %>".
              <% else %>
                Todavía no hay memorias guardadas. Se crean automáticamente cuando una conversación supera <%= Memory::TRIGGER_COUNT %> mensajes, o con el comando <code class="font-mono">/resumir</code>.
              <% end %>
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </main>
</div>
