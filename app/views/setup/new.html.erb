<% content_for :title, "Setup inicial" %>

<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="text-amber-400 font-bold tracking-widest text-sm uppercase">M I K H A E L</div>
      <p class="text-zinc-500 text-xs mt-2 italic">«¿Quién como Dios?»</p>
    </div>

    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">
      <h1 class="text-zinc-100 text-lg font-medium mb-1">Creá tu cuenta de administrador</h1>
      <p class="text-zinc-500 text-xs mb-5 leading-relaxed">
        Es la primera vez que abrís Mikhael — vamos a crear el usuario admin
        que va a manejar el resto (contexto, devices, otras cuentas).
        Después de esto, el setup queda cerrado.
      </p>

      <% if @user.errors.any? %>
        <div class="mb-4 p-3 bg-red-500/10 border border-red-500/40 rounded-lg">
          <p class="text-xs text-red-400 font-medium">No se pudo crear:</p>
          <ul class="text-xs text-red-300 mt-1 space-y-0.5">
            <% @user.errors.full_messages.each do |msg| %>
              <li>• <%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @user, url: setup_path, local: true, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :email, "Email", class: "block text-xs text-zinc-500 mb-1" %>
          <%= f.email_field :email, autofocus: true, required: true, autocomplete: "username",
                class: "w-full bg-zinc-950 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-500" %>
        </div>

        <div>
          <%= f.label :password, "Contraseña (mínimo 12 caracteres)", class: "block text-xs text-zinc-500 mb-1" %>
          <%= f.password_field :password, required: true, autocomplete: "new-password",
                minlength: 12,
                class: "w-full bg-zinc-950 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-500" %>
        </div>

        <div>
          <%= f.label :telegram_chat_id, "Telegram chat_id (opcional)", class: "block text-xs text-zinc-500 mb-1" %>
          <%= f.text_field :telegram_chat_id, autocomplete: "off",
                placeholder: "Lo podés vincular después desde /settings",
                class: "w-full bg-zinc-950 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-500 font-mono" %>
        </div>

        <%= f.submit "Crear admin y entrar",
              class: "w-full px-4 py-2 bg-amber-500 hover:bg-amber-400 text-zinc-950 font-semibold rounded-lg text-sm transition-colors cursor-pointer" %>
      <% end %>

      <p class="text-xs text-zinc-600 mt-6 leading-relaxed">
        El API token para el CLI se imprime en la siguiente pantalla y queda
        en la URL flash — guardalo, no se vuelve a mostrar.
      </p>
    </div>
  </div>
</div>
