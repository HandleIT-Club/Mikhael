<% content_for :title, "Dispositivos" %>

<div class="flex h-screen w-full">
  <%# Sidebar %>
  <aside class="w-72 flex-shrink-0 border-r border-zinc-800 flex flex-col">
    <div class="p-5 border-b border-zinc-800">
      <%= link_to conversations_path, class: "text-amber-400 font-bold tracking-widest text-sm uppercase hover:text-amber-300 transition-colors" do %>
        M I K H A E L
      <% end %>
    </div>

    <div class="p-4 space-y-2">
      <%= link_to "← Volver al chat", conversations_path,
            class: "block w-full py-2 px-4 rounded-lg bg-zinc-800 hover:bg-zinc-700 text-zinc-300 text-sm transition-colors text-center" %>
      <%= link_to "⚙ Contextos", model_configs_path,
            class: "block w-full py-2 px-4 rounded-lg bg-zinc-800 hover:bg-zinc-700 text-zinc-300 text-sm transition-colors text-center" %>
    </div>

    <div class="p-4 border-t border-zinc-800">
      <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium">Microdispositivos</p>
      <p class="text-xs text-zinc-600 mt-2 leading-relaxed">
        Cada dispositivo tiene su propio system prompt y token de acceso a la API. Usá el token para autenticar requests desde el dispositivo.
      </p>
    </div>
  </aside>

  <%# Main %>
  <main class="flex-1 overflow-y-auto">
    <div class="max-w-4xl mx-auto px-8 py-6">
      <div class="flex items-baseline justify-between mb-6">
        <div>
          <h1 class="text-2xl font-thin text-amber-400 tracking-wide">Dispositivos</h1>
          <p class="text-zinc-500 text-sm mt-1">
            Endpoint: <code class="text-amber-400">POST /api/v1/action</code> · Header: <code class="text-amber-400">Authorization: Bearer &lt;token&gt;</code>
          </p>
        </div>
      </div>

      <%# Lista de dispositivos %>
      <div class="space-y-4 mb-8">
        <% @devices.each do |device| %>
          <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
            <div class="flex items-start justify-between mb-3">
              <div>
                <div class="flex items-center gap-2">
                  <h2 class="text-zinc-100 font-medium"><%= device.name %></h2>
                  <span class="text-xs px-2 py-0.5 rounded font-mono
                    <%= device.high_security? ? 'bg-red-500/10 text-red-400 border border-red-500/30' : 'bg-zinc-800 text-zinc-400 border border-zinc-700' %>">
                    <%= device.high_security? ? "🔒 alta seguridad" : "🟢 normal" %>
                  </span>
                </div>
                <p class="text-xs text-zinc-500 mt-0.5 font-mono"><%= device.device_id %></p>
              </div>

              <%= button_to device_path(device), method: :delete,
                    class: "p-1.5 rounded text-zinc-600 hover:text-red-400 transition-colors",
                    data: { turbo_confirm: "¿Eliminar #{device.name}?" } do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              <% end %>
            </div>

            <%# Token (solo se muestra recién creado o regenerado) %>
            <% if @reveal_device_id == device.id && @reveal_token %>
              <div class="mb-3 p-3 bg-amber-500/5 border border-amber-500/40 rounded-lg space-y-1">
                <p class="text-xs text-amber-400 font-medium">Token nuevo — guardalo, no se vuelve a mostrar.</p>
                <code class="block text-xs text-amber-300 font-mono break-all"><%= @reveal_token %></code>
              </div>
            <% else %>
              <div class="mb-3 p-2 bg-zinc-950 border border-zinc-800 rounded-lg flex items-center gap-2">
                <span class="text-xs text-zinc-600">Token:</span>
                <code class="text-xs text-zinc-600 font-mono">••••••••••••••••••••••••</code>
                <%= button_to "Regenerar", regenerate_token_device_path(device),
                      method: :post,
                      class: "ml-auto text-xs text-amber-400 hover:text-amber-300 cursor-pointer",
                      data: { turbo_confirm: "Regenerar invalida el token actual. ¿Continuar?" } %>
              </div>
            <% end %>

            <%# Panel de comando directo %>
            <details class="mb-3">
              <summary class="text-xs text-amber-400 cursor-pointer hover:text-amber-300 transition-colors select-none">⚡ Comandar este dispositivo</summary>
              <div class="mt-2">
                <%= render "devices/command_frame", device: device, result: nil, error: nil, last_message: nil %>
              </div>
            </details>

            <%# Formulario de edición %>
            <%= form_with model: device, local: true, class: "space-y-3" do |f| %>
              <%= f.text_area :system_prompt, rows: 4,
                    class: "w-full bg-zinc-950 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-500 resize-none font-mono leading-relaxed",
                    placeholder: "System prompt para este dispositivo..." %>

              <div>
                <%= f.text_field :actions,
                      placeholder: "open_valve, close_valve, schedule_irrigation",
                      class: "w-full bg-zinc-950 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-500 font-mono" %>
                <p class="text-xs text-zinc-600 mt-1">Acciones del firmware, separadas por coma. El ESP32 debe implementar cada una.</p>
                <% if device.actions_list.any? %>
                  <p class="text-xs text-zinc-500 mt-1">Topic MQTT: <code class="text-amber-400 font-mono">mikhael/devices/<%= device.device_id %>/command</code></p>
                <% end %>
              </div>

              <div class="flex items-center gap-3">
                <label class="text-xs text-zinc-500">Seguridad:</label>
                <%= f.select :security_level,
                      [["🟢 Normal", "normal"], ["🔒 Alta (requiere confirmación)", "high"]],
                      { selected: device.security_level },
                      class: "bg-zinc-800 border border-zinc-700 rounded-lg px-2 py-1.5 text-xs text-zinc-300 focus:outline-none focus:border-amber-500" %>

                <div class="flex-1"></div>

                <%= f.submit "Guardar",
                      class: "px-4 py-1.5 bg-amber-500 hover:bg-amber-400 text-zinc-950 font-semibold rounded-lg text-sm transition-colors cursor-pointer" %>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if @devices.empty? %>
          <p class="text-zinc-600 text-sm text-center py-8">No hay dispositivos registrados todavía. Creá uno con el formulario de abajo.</p>
        <% end %>
      </div>

      <%# Formulario nuevo dispositivo %>
      <div class="bg-zinc-900 border border-zinc-800 border-dashed rounded-xl p-5">
        <h3 class="text-zinc-400 font-medium text-sm mb-4">+ Nuevo dispositivo</h3>

        <%= form_with model: @new_device, url: devices_path, local: true, class: "space-y-3" do |f| %>
          <div class="grid grid-cols-2 gap-3">
            <%= f.text_field :device_id, placeholder: "riego_01",
                  class: "bg-zinc-950 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-500 font-mono" %>
            <%= f.text_field :name, placeholder: "Riego automático",
                  class: "bg-zinc-950 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-500" %>
          </div>

          <%= f.text_area :system_prompt, rows: 3, placeholder: "Describí el rol y las acciones posibles de este dispositivo...",
                class: "w-full bg-zinc-950 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-500 resize-none font-mono" %>

          <%= f.text_field :actions, placeholder: "open_valve, close_valve, schedule_irrigation",
                class: "w-full bg-zinc-950 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:border-amber-500 font-mono" %>

          <div class="flex items-center gap-3">
            <label class="text-xs text-zinc-500">Seguridad:</label>
            <%= f.select :security_level,
                  [["🟢 Normal", "normal"], ["🔒 Alta", "high"]],
                  { selected: "normal" },
                  class: "bg-zinc-800 border border-zinc-700 rounded-lg px-2 py-1.5 text-xs text-zinc-300 focus:outline-none focus:border-amber-500" %>
            <div class="flex-1"></div>
            <%= f.submit "Crear dispositivo",
                  class: "px-4 py-2 bg-zinc-700 hover:bg-zinc-600 text-zinc-200 font-medium rounded-lg text-sm transition-colors cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </main>
</div>
