# Uso: mikhael [-a]
#   -a  Modo agente (detecta y ejecuta comandos de shell)

RAILS_PROJECT = ENV.fetch("MIKHAEL_PROJECT", File.expand_path("~/mikhael"))

# Usamos el Gemfile del proyecto Mikhael para tener Faraday (con retries
# automáticos), sin importar desde qué directorio se invoque el CLI.
ENV["BUNDLE_GEMFILE"] = File.join(RAILS_PROJECT, "Gemfile")
require "bundler/setup"

require "net/http"
require "json"
require "uri"
require "readline"
require "socket"
require "io/console"  # noecho para password input
require "faraday"
require "faraday/retry"

# Cargar variables del .env del proyecto Mikhael (sin pisar las que ya estén en el shell).
env_file = File.join(RAILS_PROJECT, ".env")
if File.exist?(env_file)
  File.foreach(env_file) do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#")
    key, val = line.split("=", 2)
    next unless key && val
    ENV[key.strip] ||= val.strip.gsub(/\A["']|["']\z/, "")
  end
end

RAILS_URL = ENV.fetch("MIKHAEL_URL", "http://localhost:3000")
ENV_FILE  = File.join(RAILS_PROJECT, ".env")

# Si MIKHAEL_API_TOKEN está vacío y la DB está vacía (primer arranque), el
# Onboarding wizard lo va a crear y guardar acá automáticamente. Si la DB
# tiene users pero el token está vacío/inválido, fallamos limpio más abajo
# con instrucciones para regenerar.

module C
  RST  = "\033[0m"
  BOLD = "\033[1m"
  CYN  = "\033[0;36m"
  GRN  = "\033[0;32m"
  YEL  = "\033[1;33m"
  RED  = "\033[0;31m"
  GOLD = "\033[1;38;5;220m"
  IVRY = "\033[1;38;5;230m"
  DIM  = "\033[2m"

  def self.cyan(s)    = "#{CYN}#{s}#{RST}"
  def self.green(s)   = "#{GRN}#{s}#{RST}"
  def self.yellow(s)  = "#{YEL}#{s}#{RST}"
  def self.red(s)     = "#{RED}#{s}#{RST}"
  def self.bold(s)    = "#{BOLD}#{s}#{RST}"
  def self.gold(s)    = "#{GOLD}#{s}#{RST}"
  def self.ivory(s)   = "#{IVRY}#{s}#{RST}"
  def self.dim(s)     = "#{DIM}#{s}#{RST}"
end

# ─── Cliente Rails API ─────────────────────────────────────────────────────────
#
# Faraday con retries automáticos (2 reintentos con backoff). Una red local
# que parpadea, un Rails que tarda en arrancar, o un upstream lento ya no
# rebota al usuario inmediatamente.

class RailsClient
  BASE = RAILS_URL

  # Errores propios (clases dedicadas) — el main al final del archivo los
  # rescata y sale limpio con mensaje útil, sin stack trace fea.
  class AuthError       < StandardError; end
  class ConnectionError < StandardError; end

  @api_token = ENV["MIKHAEL_API_TOKEN"].to_s.strip

  class << self
    attr_accessor :api_token

    # Tras setear un token nuevo (post-onboarding), invalidamos la connection
    # memoizada para que la próxima request use el header actualizado.
    def reset_connection!
      @connection = nil
    end
  end

  def self.connection
    @connection ||= Faraday.new(url: BASE) do |conn|
      conn.request :retry,
                   max: 2,
                   interval: 0.5,
                   backoff_factor: 2,
                   methods: %i[get post patch delete],
                   retry_statuses: [ 429, 502, 503, 504 ],
                   exceptions: [ Faraday::TimeoutError, Faraday::ConnectionFailed, Errno::ECONNREFUSED ]
      conn.headers["Content-Type"]  = "application/json"
      conn.headers["Accept"]        = "application/json"
      conn.headers["Authorization"] = "Bearer #{api_token}" if api_token.to_s.strip != ""
      conn.options.timeout      = 120
      conn.options.open_timeout = 5
      conn.adapter Faraday.default_adapter
    end
  end

  def self.get(path)         = request(:get,    path)
  def self.post(path, body = nil)  = request(:post,   path, body)
  def self.patch(path, body = nil) = request(:patch,  path, body)
  def self.delete(path)      = request(:delete, path)

  def self.request(verb, path, body = nil)
    response = connection.public_send(verb, path) do |req|
      req.body = body.to_json if body
    end

    raise AuthError, "Token inválido (401)." if response.status == 401

    JSON.parse(response.body) rescue nil
  rescue Faraday::ConnectionFailed
    raise ConnectionError, "No se puede conectar al servidor Mikhael en #{BASE}. ¿Está corriendo 'bin/dev'?"
  end
end

# ─── Onboarding wizard (primer arranque) ──────────────────────────────────────
#
# Si la DB está vacía, crea el primer admin desde el CLI. Equivalente al
# wizard del browser en /setup, pero interactivo desde la terminal.
#
# Detecta pristine vía GET /setup → 200 (form HTML). Si hay users, /setup
# redirige al login (302) y el wizard NO se dispara.
#
# Tras crear el admin, guarda el token plain en MIKHAEL_API_TOKEN del .env
# del proyecto (o lo agrega si no estaba). El user no necesita hacer nada
# manual.

class OnboardingWizard
  MIN_PASSWORD = 12

  def self.needed?
    res = Net::HTTP.get_response(URI("#{RAILS_URL}/setup"))
    res.code.to_i == 200
  rescue StandardError
    false
  end

  def self.run!(env_file:)
    puts
    puts C.gold("╔══════════════════════════════════════╗")
    puts C.gold("║") + C.ivory("       Primer arranque — setup        ") + C.gold("║")
    puts C.gold("╚══════════════════════════════════════╝")
    puts C.dim("  La DB está vacía. Vamos a crear tu cuenta de administrador.")
    puts C.dim("  Esto se hace una sola vez.")
    puts

    email    = prompt_email
    password = prompt_password
    telegram = prompt_optional("Telegram chat_id (opcional, Enter para saltar): ")

    body = {
      user: {
        email:            email,
        password:         password,
        telegram_chat_id: telegram.presence
      }
    }

    response = post_json(URI("#{RAILS_URL}/setup"), body)

    if response.code.to_i == 201
      data = JSON.parse(response.body)
      save_token_to_env(data["api_token"], env_file)
      RailsClient.api_token = data["api_token"]
      RailsClient.reset_connection!

      puts
      puts C.green("✓ Admin creado: #{data['email']}")
      puts C.green("✓ Token guardado en #{env_file}")
      puts
    else
      errors =
        begin
          parsed = JSON.parse(response.body)
          parsed["errors"] || [ parsed.inspect ]
        rescue JSON::ParserError
          [ "Server respondió status #{response.code} con body no-JSON (primeros 200 chars):", response.body.to_s[0..200] ]
        end

      puts
      puts C.red("✗ No se pudo crear el admin:")
      errors.each { |e| puts C.red("    · #{e}") }
      puts
      puts C.yellow("  Reintentá corriendo 'mikhael' otra vez.")
      exit 1
    end
  end

  # ── prompts ─────────────────────────────────────────────────────────────

  def self.prompt_email
    loop do
      print C.cyan("  Email: ")
      input = $stdin.gets&.chomp&.strip.to_s
      return input if input =~ URI::MailTo::EMAIL_REGEXP
      puts C.red("  ✗ Email inválido, probá de nuevo.")
    end
  end

  def self.prompt_password
    loop do
      input = read_password("  Contraseña (mínimo #{MIN_PASSWORD} chars, oculta): ")
      if input.length >= MIN_PASSWORD
        confirm = read_password("  Confirmar contraseña: ")
        return input if input == confirm
        puts C.red("  ✗ No coinciden, probá de nuevo.")
      else
        puts C.red("  ✗ Muy corta (#{input.length} de #{MIN_PASSWORD}), probá de nuevo.")
      end
    end
  end

  # Lee password con echo oculto si stdin es TTY. Si no (pipe/redirect en
  # tests), lee normal — noecho tira Errno::ENOTTY en ese caso.
  def self.read_password(label)
    print C.cyan(label)
    input = if $stdin.tty?
              $stdin.noecho(&:gets).to_s.chomp
    else
              $stdin.gets.to_s.chomp
    end
    puts
    input
  end

  def self.prompt_optional(label)
    print C.cyan("  #{label}")
    $stdin.gets&.chomp&.strip.to_s
  end

  # ── HTTP + env file ────────────────────────────────────────────────────

  def self.post_json(uri, body)
    Net::HTTP.start(uri.host, uri.port, use_ssl: uri.scheme == "https") do |http|
      req = Net::HTTP::Post.new(uri)
      req["Content-Type"] = "application/json"
      req["Accept"]       = "application/json"
      req.body            = body.to_json
      http.request(req)
    end
  end

  # Reescribe (o agrega) la línea MIKHAEL_API_TOKEN= en el .env del proyecto.
  # No usa una gem porque queremos mantener el CLI sin dotenv-rails.
  def self.save_token_to_env(token, env_file)
    lines    = File.exist?(env_file) ? File.readlines(env_file, chomp: true) : []
    new_line = "MIKHAEL_API_TOKEN=#{token}"

    if lines.any? { |l| l.start_with?("MIKHAEL_API_TOKEN=") }
      lines.map! { |l| l.start_with?("MIKHAEL_API_TOKEN=") ? new_line : l }
    else
      lines << new_line
    end

    File.write(env_file, "#{lines.join("\n")}\n")
  end
end

# Refinement local: String#presence (sin Rails)
class String
  def presence = empty? ? nil : self
end

class NilClass
  def presence = nil
end

# ─── Detector de comandos ──────────────────────────────────────────────────────

class CommandDetector
  TRIPLE_BLOCK   = /```(?:bash|shell|sh|zsh|console|terminal)\n?([\s\S]*?)```/i
  SINGLE_TICK    = /(?<!`)`(?!`)([^`\n]+?)(?<!`)`(?!`)/
  PLACEHOLDER    = /\/(ruta|path|your|usuario|user|example|carpeta|folder|directorio)\b/i
  SHELL_COMMANDS = %w[
    ls cd pwd echo cat cp mv rm mkdir touch chmod chown grep find curl wget
    git ruby python python3 bash sh gem bundle rails rake npm node make sudo
    apt brew open code vim nano awk sed head tail wc sort uniq xargs tr cut
    date whoami which man history clear ping ssh tar zip unzip ollama
  ].to_set

  def self.extract(text)
    cmds = text.scan(TRIPLE_BLOCK).flatten
               .flat_map { |b| b.strip.lines }
               .map { |l| l.strip.sub(/^[$#]\s*/, "") }
               .reject(&:empty?)
               .reject { |c| PLACEHOLDER.match?(c) }

    if cmds.empty?
      cmds = text.scan(SINGLE_TICK).flatten
                 .map(&:strip).reject(&:empty?)
                 .select { |c| shell_command?(c) }
                 .reject { |c| PLACEHOLDER.match?(c) }
    end

    cmds.uniq
  end

  def self.shell_command?(cmd)
    first = cmd.split.first || ""
    first = cmd.split[1] if first == "sudo"
    SHELL_COMMANDS.include?(first)
  end
end

# ─── Ejecutor de comandos ──────────────────────────────────────────────────────

class CommandRunner
  def self.confirm_and_run(command, silent: false)
    puts
    puts C.yellow("╔══ Comando detectado ══════════════════╗")
    puts C.yellow("║ ") + C.bold(command)
    puts C.yellow("╚═══════════════════════════════════════╝")
    print C.yellow("¿Ejecutar? [s/N]: ")

    return nil unless $stdin.gets&.chomp&.downcase == "s"

    output = capture(command, silent: silent)
    puts C.green("✓ Finalizado.")
    output
  end

  def self.capture(command, silent: false)
    lines = []
    IO.popen([ "bash", "-c", command ], err: [ :child, :out ]) do |io|
      io.each_line { |l| print l unless silent; lines << l }
    end
    lines.join
  rescue => e
    puts C.red("Error: #{e.message}")
    nil
  end
end

# ─── Gestión de dispositivos ───────────────────────────────────────────────────

class DevicesMenu
  SECURITY_LABELS = { "normal" => "🟢 normal", "high" => "🔒 alta seguridad" }.freeze

  def self.run
    loop do
      devices = RailsClient.get("/api/v1/devices") || []

      puts
      puts C.gold("╔══ Dispositivos ═══════════════════════╗")
      if devices.empty?
        puts C.gold("║") + C.dim("  (ningún dispositivo registrado)      ") + C.gold("║")
      else
        devices.each_with_index do |d, i|
          label   = SECURITY_LABELS[d["security_level"]] || d["security_level"]
          actions = Array(d["actions"]).any? ? C.dim(" · #{Array(d['actions']).join(', ')}") : ""
          puts C.gold("║") + " #{C.yellow("[#{i + 1}]")} #{d['name']} #{C.dim("(#{d['device_id']})")} — #{label}#{actions}"
        end
      end
      puts C.gold("╠═══════════════════════════════════════╣")
      puts C.gold("║") + " #{C.yellow("[n]")} Nuevo dispositivo"
      puts C.gold("║") + " #{C.yellow("[c#]")} Comandar  (ej: c1)"
      puts C.gold("║") + " #{C.yellow("[e#]")} Editar    (ej: e1)"
      puts C.gold("║") + " #{C.yellow("[r#]")} Regenerar token (ej: r1)"
      puts C.gold("║") + " #{C.yellow("[x#]")} Eliminar  (ej: x1)"
      puts C.gold("║") + " #{C.yellow("[v]")} Volver al chat"
      puts C.gold("╚═══════════════════════════════════════╝")
      print C.cyan("Opción: ")

      choice = $stdin.gets&.chomp&.strip&.downcase
      return if choice.nil? || %w[v volver back].include?(choice)

      if choice == "n"
        create_device
      elsif choice =~ /^c(\d+)$/
        idx = $1.to_i - 1
        command_device(devices[idx]) if idx >= 0 && idx < devices.length
      elsif choice =~ /^e(\d+)$/
        idx = $1.to_i - 1
        edit_device(devices[idx]) if idx >= 0 && idx < devices.length
      elsif choice =~ /^r(\d+)$/
        idx = $1.to_i - 1
        regenerate_token(devices[idx]) if idx >= 0 && idx < devices.length
      elsif choice =~ /^x(\d+)$/
        idx = $1.to_i - 1
        delete_device(devices[idx]) if idx >= 0 && idx < devices.length
      end
    end
  end

  def self.command_device(device)
    return unless device

    puts
    puts C.bold("Comandar: #{device['name']}")
    puts C.dim("  El dispositivo interpretará tu mensaje y devolverá una acción.")
    print C.cyan("  Mensaje: ")
    message = $stdin.gets&.chomp&.strip
    return if message.nil? || message.empty?

    puts C.dim("  Enviando...")
    result = RailsClient.post("/api/v1/devices/#{device['id']}/command", { message: message })

    if result&.key?("action")
      puts C.green("  ✓ Acción: ") + C.bold(result["action"].to_s)
      puts C.gold("  Valor:   ") + result["value"].to_s if result["value"]
      puts C.dim("  Razón:   #{result['reason']}")
      puts C.red("  ⚠ Alta seguridad — requiere confirmación manual en el dispositivo.") if result["requires_confirmation"]
    else
      puts C.red("  ✗ Error: #{result&.dig('error') || 'respuesta inválida'}")
    end
  end

  def self.regenerate_token(device)
    return unless device

    print C.red("  Regenerar invalida el token actual de '#{device['name']}'. ¿Continuar? [s/N]: ")
    return puts(C.dim("  Cancelado.")) unless $stdin.gets&.chomp&.downcase == "s"

    result = RailsClient.post("/api/v1/devices/#{device['id']}/regenerate_token")

    if result&.key?("token")
      puts C.green("  ✓ Token regenerado.")
      puts C.gold("  Token: ") + C.bold(result["token"])
      puts C.dim("  Guardalo — no se vuelve a mostrar.")
    else
      puts C.red("  ✗ Error: #{result&.dig('error') || 'respuesta inválida'}")
    end
  end

  def self.create_device
    puts
    puts C.bold("Nuevo dispositivo")
    print C.cyan("  ID único (ej: riego_01): ")
    device_id = $stdin.gets&.chomp&.strip
    return if device_id.nil? || device_id.empty?

    print C.cyan("  Nombre descriptivo: ")
    name = $stdin.gets&.chomp&.strip
    return if name.nil? || name.empty?

    puts C.cyan("  System prompt (describí el rol y las acciones posibles):")
    print "  > "
    system_prompt = $stdin.gets&.chomp&.strip
    return if system_prompt.nil? || system_prompt.empty?

    print C.cyan("  Acciones del firmware (ej: open_valve, close_valve): ")
    actions = $stdin.gets&.chomp&.strip

    print C.cyan("  Seguridad — [1] Normal  [2] Alta (requiere confirmación): ")
    sec_choice = $stdin.gets&.chomp&.strip
    security_level = sec_choice == "2" ? "high" : "normal"

    result = RailsClient.post("/api/v1/devices", {
      device: { device_id: device_id, name: name, system_prompt: system_prompt, security_level: security_level, actions: actions }
    })

    if result&.key?("token")
      puts C.green("  ✓ Dispositivo creado.")
      puts C.gold("  Token: ") + C.bold(result["token"])
      puts C.dim("  Guardá este token — lo necesitás para autenticar requests desde el dispositivo.")
      if Array(result["actions"]).any?
        puts C.dim("  Topic MQTT: mikhael/devices/#{result['device_id']}/command")
      end
    else
      puts C.red("  ✗ Error: #{result&.dig('error') || 'respuesta inválida'}")
    end
  end

  def self.edit_device(device)
    return unless device

    puts
    puts C.bold("Editando: #{device['name']}")
    puts C.dim("  (Enter para mantener el valor actual)")
    puts

    puts C.cyan("  System prompt actual:")
    puts C.dim("  #{device['system_prompt']}")
    print C.cyan("  Nuevo (enter para mantener): ")
    new_prompt = $stdin.gets&.chomp
    system_prompt = (new_prompt.nil? || new_prompt.strip.empty?) ? device["system_prompt"] : new_prompt.strip

    current_actions = Array(device["actions"]).join(", ")
    print C.cyan("  Acciones actuales: #{current_actions.empty? ? '(ninguna)' : current_actions} — nuevas (enter para mantener): ")
    new_actions_raw = $stdin.gets&.chomp
    actions = (new_actions_raw.nil? || new_actions_raw.strip.empty?) ? current_actions : new_actions_raw.strip

    current_sec = SECURITY_LABELS[device["security_level"]]
    print C.cyan("  Seguridad actual: #{current_sec} — [1] Normal  [2] Alta  [enter] mantener: ")
    sec_choice = $stdin.gets&.chomp&.strip
    security_level = case sec_choice
    when "1" then "normal"
    when "2" then "high"
    else device["security_level"]
    end

    result = RailsClient.patch("/api/v1/devices/#{device['id']}", {
      device: { system_prompt: system_prompt, security_level: security_level, actions: actions }
    })

    if result&.key?("id")
      puts C.green("  ✓ Guardado.")
    else
      puts C.red("  ✗ Error: #{result&.dig('error') || 'respuesta inválida'}")
    end
  end

  def self.delete_device(device)
    return unless device

    print C.red("  ¿Eliminar '#{device['name']}'? [s/N]: ")
    confirm = $stdin.gets&.chomp&.downcase
    if confirm == "s"
      RailsClient.delete("/api/v1/devices/#{device['id']}")
      puts C.green("  ✓ Eliminado.")
    else
      puts C.dim("  Cancelado.")
    end
  end
end

# ─── Gestión de memorias ──────────────────────────────────────────────────────

class MemoriesMenu
  def self.run
    new.run
  end

  def run
    loop do
      memories = RailsClient.get("/api/v1/memories") || []

      puts
      puts C.gold("Memorias guardadas (#{memories.length}):")

      if memories.empty?
        puts C.dim("  No hay memorias todavía. Se crean automáticamente con /resumir o al llegar a 20 mensajes.")
        puts
        return
      end

      memories.each_with_index do |m, i|
        date = Time.parse(m["created_at"]).strftime("%d/%m/%Y %H:%M") rescue m["created_at"]
        puts "  #{C.yellow("[#{i + 1}]")} #{C.dim(date)}"
        puts "      #{m['summary']}"
        puts "      #{C.dim(m['keywords'])}"
        puts
      end

      puts "  #{C.yellow("[b#]")} Buscar por keyword (ej: b rails)"
      puts "  #{C.red("[x#]")} Eliminar (ej: x1)"
      puts "  #{C.dim("[enter]")} Volver"
      print C.cyan("Elegí: ")
      choice = $stdin.gets&.chomp&.strip

      break if choice.nil? || choice.empty?

      if choice =~ /^b\s+(.+)$/i
        keyword = $1.strip
        results = RailsClient.get("/api/v1/memories?q=#{URI.encode_www_form_component(keyword)}") || []
        puts
        if results.empty?
          puts C.yellow("  Sin resultados para '#{keyword}'.")
        else
          puts C.gold("  Memorias con '#{keyword}':")
          results.each do |m|
            date = Time.parse(m["created_at"]).strftime("%d/%m") rescue ""
            puts "  #{C.dim(date)} #{m['summary']}"
          end
        end
        puts
        next
      end

      if choice =~ /^x(\d+)$/i
        idx = $1.to_i - 1
        if idx >= 0 && idx < memories.length
          memory = memories[idx]
          print C.red("¿Eliminar esta memoria? [s/N]: ")
          if $stdin.gets&.chomp&.downcase == "s"
            RailsClient.delete("/api/v1/memories/#{memory['id']}")
            puts C.green("  ✓ Memoria eliminada.")
          else
            puts C.dim("  Cancelado.")
          end
        else
          puts C.red("  Número inválido.")
        end
        next
      end

      break
    end
  end
end

# ─── Agente ───────────────────────────────────────────────────────────────────

class Agent
  PROVIDER_LABELS = {
    "groq"      => "groq · nube",
    "cerebras"  => "cerebras · nube",
    "sambanova" => "sambanova · nube",
    "ollama"    => "ollama · local"
  }.freeze

  TIER_LABELS = {
    "advanced"     => "avanzado",
    "intermediate" => "intermedio",
    "basic"        => "básico"
  }.freeze

  def initialize(agent_mode:)
    @agent_mode = agent_mode
    @models     = []
  end

  def run
    print_header
    check_server
    maybe_run_onboarding
    ensure_token_present!
    load_models
    @conversation = select_or_create_conversation
    if @conversation.nil?
      puts C.gold("¡Hasta luego!")
      stop_services
      return
    end
    chat_loop
    puts C.gold("¡Hasta luego!")
    stop_services
  end

  private

  # ── Servidor ──────────────────────────────────────────────────────

  def check_server
    ensure_ollama_running
    ensure_rails_running
    ensure_jobs_running
    puts C.green("✓ Servidor conectado — #{RAILS_URL}")
    print_integrations_status
    puts
  end

  # ── Onboarding (primer arranque) ──────────────────────────────────

  def maybe_run_onboarding
    return unless OnboardingWizard.needed?
    OnboardingWizard.run!(env_file: ENV_FILE)
  end

  # Si pasamos onboarding y todavía no hay token (porque el user canceló o
  # el .env no se pudo escribir), salimos con instrucciones claras antes de
  # disparar la primera request autenticada.
  def ensure_token_present!
    return if RailsClient.api_token.to_s.strip != ""

    puts
    puts C.red("✗ No hay MIKHAEL_API_TOKEN configurado.")
    puts
    puts C.yellow("  Si es la primera vez, corré 'bin/rails db:prepare' y volvé a")
    puts C.yellow("  arrancar Mikhael — el wizard te va a guiar.")
    puts C.yellow("  Si ya tenés users, regenerá un token con:")
    puts C.cyan("    bin/rails users:regenerate_token EMAIL=tu@email.com")
    puts C.yellow("  Y guardalo como MIKHAEL_API_TOKEN= en #{ENV_FILE}")
    stop_services
    exit 1
  end

  def print_integrations_status
    providers = [
      [ "Groq",      "GROQ_API_KEY" ],
      [ "Cerebras",  "CEREBRAS_API_KEY" ],
      [ "SambaNova", "SAMBANOVA_API_KEY" ]
    ]
    keys_line = providers.map do |name, env|
      ENV[env].to_s.strip.empty? ? C.red("✗ #{name}") : C.green("✓ #{name}")
    end.join(" · ")
    puts C.dim("  API keys:     ") + keys_line

    mqtt = ENV["MQTT_URL"].to_s.strip
    puts C.dim("  MQTT push:    ") + (mqtt.empty? ? C.red("✗ desactivado") : C.green("✓ activo  #{C.dim(mqtt)}"))

    tg_token = ENV["TELEGRAM_BOT_TOKEN"].to_s.strip
    if tg_token.empty?
      puts C.dim("  Telegram bot: ") + C.red("✗ desactivado") + C.dim(" (sin TELEGRAM_BOT_TOKEN)")
    else
      # Multi-user: el chat_id vive por user en la DB, no en ENV. No lo
      # podemos chequear desde el CLI sin tocar Rails — solo confirmamos
      # que el token esté seteado.
      puts C.dim("  Telegram bot: ") + C.green("✓ token configurado") + C.dim(" (vinculá users en Configuración)")
    end

    missing = providers.count { |_, env| ENV[env].to_s.strip.empty? }
    if missing == providers.length
      puts C.red("  ⚠ No tenés ninguna API key. Agregá al menos GROQ_API_KEY al .env.")
    end
  end

  def ensure_ollama_running
    return if port_open?("localhost", 11434)
    puts C.cyan("⚡ Iniciando Ollama...")
    @ollama_pid = Process.spawn("ollama serve", out: "/dev/null", err: "/dev/null", pgroup: 0)
    wait_for("Ollama", "localhost", 11434)
  end

  def ensure_rails_running
    uri = URI(RAILS_URL)
    if port_open?(uri.host, uri.port)
      wait_for_rails_ready  # ya está corriendo, igual confirmamos que responde /up
      return
    end
    puts C.cyan("⚡ Iniciando Rails...")
    @rails_pid = Process.spawn(
      "bin/rails server -p #{uri.port}",
      chdir: RAILS_PROJECT, out: "/dev/null", err: "/dev/null", pgroup: 0
    )
    wait_for("Rails", uri.host, uri.port)
    wait_for_rails_ready
  end

  # SolidQueue procesa el polling de Telegram, los recordatorios, y todos
  # los recurring tasks. Si no corre, Telegram no responde (bug clásico —
  # el user veía "no responde" porque no había job que procese updates).
  #
  # Si ya hay un proceso solid_queue corriendo (típicamente porque el user
  # tiene `bin/dev` aparte), no lanzamos otro. Si no, lo arrancamos en
  # background y lo apagamos al salir.
  def ensure_jobs_running
    if solid_queue_running?
      puts C.dim("  Jobs (SolidQueue): ya en ejecución (compartido con bin/dev).")
      return
    end

    puts C.cyan("⚡ Iniciando SolidQueue (jobs)...")
    @jobs_pid = Process.spawn(
      "bin/jobs",
      chdir: RAILS_PROJECT, out: "/dev/null", err: "/dev/null", pgroup: 0
    )
    # Damos un par de segundos para que registre el scheduler de recurring.
    # No hay un /up de SolidQueue — confiamos en el sleep + el log.
    sleep 2
    puts C.green("  ✓ Jobs lanzados (PID #{@jobs_pid}).")
  end

  def solid_queue_running?
    # pgrep -f matchea por command line. Buscamos el proceso supervisor.
    system("pgrep -f 'solid_queue' > /dev/null 2>&1")
  end

  def stop_services
    if @jobs_pid
      puts C.cyan("  Cerrando jobs...")
      Process.kill("-TERM", -@jobs_pid) rescue nil
      Process.wait(@jobs_pid) rescue nil
    end
    if @rails_pid
      puts C.cyan("  Cerrando Rails...")
      Process.kill("-TERM", -@rails_pid) rescue nil
      Process.wait(@rails_pid) rescue nil
    end
    if @ollama_pid
      puts C.cyan("  Cerrando Ollama...")
      Process.kill("-TERM", -@ollama_pid) rescue nil
      Process.wait(@ollama_pid) rescue nil
    end
  end

  def port_open?(host, port)
    TCPSocket.new(host, port).close
    true
  rescue Errno::ECONNREFUSED, Errno::EHOSTUNREACH, SocketError
    false
  end

  def wait_for(name, host, port, timeout: 30)
    print C.cyan("  Esperando #{name}")
    timeout.times do
      return puts(C.green(" listo")) if port_open?(host, port)
      print "."
      sleep 1
    end
    puts
    puts C.red("✗ #{name} no arrancó en #{timeout}s. Verificá manualmente.")
    exit 1
  end

  # Healthcheck real al endpoint /up de Rails. TCP open != app cargada —
  # Puma bindea el puerto antes de terminar el eager_load, y cualquier
  # request prematura puede recibir 500 sin que sepamos.
  def wait_for_rails_ready(timeout: 30)
    uri = URI("#{RAILS_URL}/up")
    print C.cyan("  Verificando app")
    timeout.times do
      begin
        res = Net::HTTP.get_response(uri)
        return puts(C.green(" lista")) if res.code.to_i == 200
      rescue StandardError
        # connect/read errors: app todavía no responde, seguimos esperando
      end
      print "."
      sleep 1
    end
    puts
    puts C.red("✗ Rails no respondió 200 en /up tras #{timeout}s. Revisá log/development.log.")
    exit 1
  end

  # ── Modelos ───────────────────────────────────────────────────────

  def load_models
    result = RailsClient.get("/api/v1/models")

    if result.is_a?(Array)
      @models = result
      return
    end

    # Si vino algo que no es array (nil por JSON malformado, hash de error
    # del server, etc.), no procedemos en silencio — el usuario tiene que
    # saber qué pasó. Antes esto resultaba en "No hay modelos disponibles"
    # ambiguo y sin pista de la causa raíz.
    puts C.red("✗ /api/v1/models devolvió una respuesta inesperada (#{result.class}).")
    puts C.dim("  Body: #{result.inspect[0..300]}")
    puts C.yellow("  Probable causa: server crasheando al cargar. Revisá log/development.log")
    puts C.yellow("  o regenerá tu token con: bin/rails users:regenerate_token EMAIL=...")
    @models = []
    # Errores específicos (AuthError, ConnectionError) NO se rescatan acá —
    # propagan hasta main que muestra mensaje claro y sale con exit 1.
    # Otros errores sí se manejan acá para no romper el menú de conversaciones.
  rescue RailsClient::AuthError, RailsClient::ConnectionError
    raise
  rescue => e
    puts C.yellow("⚠ No se pudieron cargar modelos: #{e.message}")
    @models = []
  end

  def model_label(m)
    provider = PROVIDER_LABELS[m["provider"]] || m["provider"]
    tier     = m["tier"] ? " · #{TIER_LABELS[m['tier']] || m['tier']}" : ""
    "%-45s %s" % [ m["model_id"], C.dim("(#{provider}#{tier})") ]
  end

  # ── Conversaciones ────────────────────────────────────────────────

  def select_or_create_conversation
    conversations = RailsClient.get("/api/v1/conversations") || []

    if conversations.any?
      puts C.gold("Conversaciones recientes:")
      conversations.first(5).each_with_index do |c, i|
        badge = PROVIDER_LABELS[c["provider"]] || c["provider"]
        puts "  #{C.yellow("[#{i + 1}]")} #{c['title']} #{C.dim("(#{badge})")}"
      end
      puts "  #{C.yellow("[n]")} Nueva conversación"
      puts "  #{C.yellow("[d]")} Gestionar dispositivos"
      puts "  #{C.yellow("[m]")} Ver memorias"
      puts "  #{C.yellow("[o]")} Abrir en el navegador"
      puts "  #{C.red("[x#]")} Eliminar (ej: x1, x2...)"
      print C.cyan("Elegí: ")
      choice = $stdin.gets&.chomp&.downcase&.strip

      return nil if exit_command?(choice)

      if choice == "d"
        DevicesMenu.run
        return select_or_create_conversation
      end

      if choice == "m"
        MemoriesMenu.run
        return select_or_create_conversation
      end

      if choice == "o"
        system("open", RAILS_URL)
        return select_or_create_conversation
      end

      if choice =~ /^x(\d+)$/
        idx = $1.to_i - 1
        if idx >= 0 && idx < conversations.length
          conv = conversations[idx]
          print C.red("¿Eliminar '#{conv['title']}'? [s/N]: ")
          if $stdin.gets&.chomp&.downcase == "s"
            RailsClient.delete("/api/v1/conversations/#{conv['id']}")
            puts C.green("✓ Conversación eliminada.")
          else
            puts C.dim("  Cancelado.")
          end
        else
          puts C.red("  Número inválido.")
        end
        return select_or_create_conversation
      end

      if choice != "n"
        idx = choice.to_i - 1
        if idx >= 0 && idx < conversations.length
          conv = conversations[idx]
          puts C.green("✓ Continuando: #{conv['title']}")
          puts
          return conv
        end
      end
    end

    create_conversation
  end

  def create_conversation
    if @models.empty?
      puts C.yellow("⚠ No hay modelos disponibles. Verificá que el servidor esté corriendo.")
      return nil
    end

    puts C.gold("Modelos disponibles:")
    @models.each_with_index do |m, i|
      puts "  #{C.yellow("[#{i + 1}]")} #{model_label(m)}"
    end
    print C.cyan("Modelo [1-#{@models.length}]: ")
    choice = $stdin.gets&.chomp&.strip

    return nil if exit_command?(choice)

    idx   = (choice.to_i - 1).clamp(0, @models.length - 1)
    model = @models[idx]

    default = "Chat #{Time.now.strftime('%d/%m %H:%M')}"
    print C.cyan("Nombre (enter para '#{default}'): ")
    input = $stdin.gets&.chomp
    return nil if exit_command?(input)
    title = (input.nil? || input.strip.empty?) ? default : input.strip

    conv = RailsClient.post("/api/v1/conversations", {
      conversation: { title: title, model_id: model["model_id"] }
    })

    if conv&.key?("id")
      puts C.green("✓ Nueva conversación: #{conv['title']} (#{model['model_id']})")
      puts
      conv
    else
      puts C.red("✗ No se pudo crear la conversación: #{conv&.dig('error') || 'error desconocido'}")
      nil
    end
  end

  # ── Chat ──────────────────────────────────────────────────────────

  def chat_loop
    loop do
      input = prompt_user
      break if exit_command?(input)
      next  if input.nil? || input.strip.empty?
      break if @conversation.nil?
      send_and_respond(input)
    end
  end

  def send_and_respond(content)
    if @agent_mode
      send_and_respond_blocking(content)
    else
      send_and_respond_streaming(content)
    end
  end

  # Modo normal: streaming token a token.
  def send_and_respond_streaming(content)
    uri = URI("#{RAILS_URL}/api/v1/conversations/#{@conversation['id']}/messages/stream")
    full_response = +""

    print C.gold("Mikhael: ")
    $stdout.flush

    Net::HTTP.start(uri.host, uri.port, read_timeout: 120) do |http|
      req = Net::HTTP::Post.new(uri,
                                "Content-Type"  => "application/json",
                                "Accept"        => "text/event-stream",
                                "Authorization" => "Bearer #{RailsClient.api_token}")
      req.body = { message: { content: content } }.to_json

      http.request(req) do |response|
        buffer = +""
        response.read_body do |raw|
          buffer << raw
          while (newline = buffer.index("\n"))
            line = buffer.slice!(0, newline + 1).strip
            next unless line.start_with?("data: ")
            data = JSON.parse(line.delete_prefix("data: ")) rescue next

            if data["chunk"]
              print data["chunk"]
              $stdout.flush
              full_response << data["chunk"]
            elsif data["error"]
              puts
              puts C.red("Error: #{data['error']}")
              return
            elsif data["done"]
              if data["model"] && data["model"] != @conversation["model_id"]
                puts
                puts C.yellow("  ↪ Modelo cambiado automáticamente a #{data['model']}")
                @conversation["model_id"] = data["model"]
              end
            end
          end
        end
      end
    end

    puts
    puts
  rescue Errno::ECONNREFUSED
    puts C.red("\nError: No se puede conectar al servidor. ¿Está corriendo 'bin/dev'?")
  rescue => e
    puts C.red("\nError: #{e.message}")
  end

  # Modo agente: espera la respuesta completa para detectar bloques de código.
  def send_and_respond_blocking(content)
    print C.gold("Mikhael (pensando...)\r")
    $stdout.flush

    result = RailsClient.post(
      "/api/v1/conversations/#{@conversation['id']}/messages",
      { message: { content: content } }
    )

    print "\r" + " " * 35 + "\r"

    if result.nil? || result["error"]
      puts C.red("Error: #{result&.dig('error') || 'sin respuesta'}")
      return
    end

    response = result["content"]

    if result["model"] && result["model"] != @conversation["model_id"]
      puts C.yellow("  ↪ Modelo cambiado automáticamente a #{result['model']}")
      @conversation["model_id"] = result["model"]
    end

    commands = CommandDetector.extract(response)
    if commands.any?
      outputs = {}
      commands.each do |cmd|
        output = CommandRunner.confirm_and_run(cmd, silent: true)
        outputs[cmd] = output.strip if output && !output.strip.empty?
      end

      unless outputs.empty?
        outputs.each do |cmd, out|
          RailsClient.post(
            "/api/v1/conversations/#{@conversation['id']}/messages",
            { message: { content: "Salida del comando `#{cmd}`:\n```\n#{out}\n```" } }
          )
        end
        print C.gold("Mikhael (analizando...)\r")
        $stdout.flush
        conclusion = RailsClient.post(
          "/api/v1/conversations/#{@conversation['id']}/messages",
          { message: { content: "Analizá la salida anterior y dame una conclusión breve." } }
        )
        print "\r" + " " * 35 + "\r"
        puts
        puts C.gold("Mikhael:") + " #{conclusion&.dig('content')}"
        puts
      end
      return
    end

    puts
    puts C.gold("Mikhael:") + " #{response}"
    puts
  end

  def prompt_user
    input = Readline.readline(C.cyan("Vos: "), true)
    return "salir" if input.nil?
    case input.strip
    when "limpiar", "nueva"
      @conversation = create_conversation
      return ""
    when "open", "abrir"
      system("open", RAILS_URL)
      return ""
    when "convs", "conversaciones", "atras", "atrás", "back"
      @conversation = select_or_create_conversation
      return "salir" if @conversation.nil?
      return ""
    when "dispositivos", "devices"
      DevicesMenu.run
      return ""
    when "memorias", "memories"
      MemoriesMenu.run
      return ""
    end
    input
  end

  def exit_command?(input)
    %w[salir exit quit q].include?(input&.strip&.downcase)
  end

  def print_header
    puts
    puts C.gold("╔══════════════════════════════════════╗")
    puts C.gold("║") + C.ivory("           M I K H A E L              ") + C.gold("║")
    puts C.gold("╚══════════════════════════════════════╝")
    puts C.cyan("Modo: #{@agent_mode ? 'Agente' : 'Chat'}")
    puts C.cyan("Comandos: salir · limpiar · convs · open · dispositivos · memorias")
    puts
  end
end

# ─── Entrada ──────────────────────────────────────────────────────────────────

agent_mode = ARGV.include?("-a") || ARGV.include?("--agent")

agent = Agent.new(agent_mode: agent_mode)

begin
  agent.run
rescue Interrupt
  puts
  puts C.gold("Interrumpido. ¡Hasta luego!")
  agent.send(:stop_services)
  exit 0
rescue RailsClient::AuthError
  puts
  puts C.red("✗ MIKHAEL_API_TOKEN inválido o expirado.")
  puts
  puts C.yellow("  Tu token (en ~/mikhael/.env) no matchea ningún user de la DB.")
  puts C.yellow("  Esto suele pasar cuando:")
  puts C.dim("    · Borraste y recreaste la DB (db:reset) — el HMAC cambió.")
  puts C.dim("    · Migraste de la versión pre-HMAC con un token nuevo.")
  puts
  puts C.yellow("  Regenerá el token con:")
  puts C.cyan("    bin/rails users:regenerate_token EMAIL=tu@email.com")
  puts C.yellow("  Y actualizá MIKHAEL_API_TOKEN= en ~/mikhael/.env")
  agent.send(:stop_services)
  exit 1
rescue RailsClient::ConnectionError => e
  puts
  puts C.red("✗ #{e.message}")
  agent.send(:stop_services)
  exit 1
end
